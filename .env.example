# --- Copie ce fichier en ".env" et remplis les valeurs ---

# Le token de ton bot Discord (Discord Developer Portal > ton app > Bot > Reset Token)
DISCORD_TOKEN=colle_ton_token_ici

# L'ID du serveur Discord (clic droit sur le nom du serveur > Copier l'ID)
GUILD_ID=id_de_ton_serveur_discord

# L'IP de ton serveur CS 1.6
SERVER_IP=127.0.0.1

# Le port du serveur CS 1.6 (souvent 27015)
SERVER_PORT=27015

# Nom affiché avant le nombre de joueurs (ex: "pGv Team")
SERVER_LABEL=Mon Serveur CS

# Intervalle de rafraîchissement en minutes (Discord limite à 2 renommages / 10 min)
REFRESH_MINUTES=6
